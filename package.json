{
  "name": "cdk-react-app",
  "version": "0.1.0",
  "bin": {
    "cdk-react-app": "bin/cdk-react-app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "postinstall": "cd node_modules/aws-cdk-lib/node_modules/minimatch && npm install minimatch@10.2.4 --install-strategy=shallow --no-save 2>/dev/null; cp -f node_modules/minimatch/* . 2>/dev/null; rm -rf node_modules; true"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.15.3",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "2.1108.0",
    "cdk-nag": "^2.35.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-python-alpha": "^2.240.0-alpha.0",
    "aws-cdk-lib": "2.240.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21",
    "uuid": "^11.1.0"
  },
  "overrides": {
    "minimatch": "10.2.4"
  }
}
